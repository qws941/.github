        {
            "parameters": {
                "httpMethod": "POST",
                "path": "github-issue",
                "options": {}
            },
            "id": "webhook-trigger",
            "name": "GitHub Issue Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                250,
                300
            ],
            "webhookId": "d69a3143-25e4-4b56-8794-99acaa9276e9"
        },
        {
            "parameters": {
                "jsCode": "// Parse GitHub issue webhook\nconst body = $input.first().json.body || $input.first().json;\nconst action = body.action;\nconst issue = body.issue || {};\nconst labels = (issue.labels || []).map(l => l.name);\nconst hasUserRequest = labels.includes('user-request');\nconst hasAutomated = labels.includes('automated');\n\n// Calculate current week milestone name\nconst now = new Date();\nconst year = now.getFullYear();\nconst startOfYear = new Date(year, 0, 1);\nconst days = Math.floor((now - startOfYear) / 86400000);\nconst weekNum = Math.ceil((days + startOfYear.getDay() + 1) / 7);\nconst milestoneTitle = `Week ${year}-W${String(weekNum).padStart(2, '0')}`;\n\nreturn [{\n  json: {\n    action,\n    isOpened: action === 'opened',\n    hasUserRequest,\n    hasAutomated,\n    shouldProcess: action === 'opened' && hasUserRequest,\n    issueNumber: issue.number,\n    issueTitle: issue.title || '',\n    issueBody: issue.body || '',\n    existingLabels: labels,\n    repo: (body.repository || {}).full_name || 'qws941/terraform',\n    milestoneTitle\n  }\n}];"
            },
            "id": "parse-event",
            "name": "Parse Issue Event",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                500,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "should-process",
                            "leftValue": "={{ $json.shouldProcess }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "true"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "filter-requests",
            "name": "Is User Request?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                940,
                500
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "=https://api.github.com/repos/{{ $json.repo }}/issues/{{ $json.issueNumber }}/comments",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "=Bearer {{ $env.GITHUB_TOKEN }}"
                        },
                        {
                            "name": "Accept",
                            "value": "application/vnd.github+json"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"body\": \"## Request Processing Checklist\\n\\n- [ ] Request reviewed and understood\\n- [ ] Priority assigned\\n- [ ] Implementation plan created\\n- [ ] Implementation completed\\n- [ ] Testing done\\n- [ ] Deployed and verified\\n- [ ] Requester notified\\n\\n---\\n*Auto-generated by n8n request tracker*\"\n}",
                "options": {}
            },
            "id": "add-checklist",
            "name": "Add Checklist Comment",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1200,
                400
            ],
            "retryOnFail": true,
            "maxTries": 3,
            "waitBetweenTries": 1000
        },
        {
            "parameters": {
                "jsCode": "// Find or create milestone for current week (with error handling)\nconst input = $input.first().json;\nconst repo = input.repo;\nconst milestoneTitle = input.milestoneTitle;\nconst issueNumber = input.issueNumber;\nconst token = $env.GITHUB_TOKEN;\n\nconst headers = {\n  'Authorization': `Bearer ${token}`,\n  'Accept': 'application/vnd.github+json',\n  'Content-Type': 'application/json'\n};\n\ntry {\n  // List milestones to find current week\n  const listRes = await fetch(`https://api.github.com/repos/${repo}/milestones?state=open`, { headers });\n  if (!listRes.ok) {\n    throw new Error(`List milestones failed: ${listRes.status} ${listRes.statusText}`);\n  }\n  const milestones = await listRes.json();\n  let milestone = milestones.find(m => m.title === milestoneTitle);\n\n  // Create if not exists\n  if (!milestone) {\n    const createRes = await fetch(`https://api.github.com/repos/${repo}/milestones`, {\n      method: 'POST',\n      headers,\n      body: JSON.stringify({ title: milestoneTitle })\n    });\n    if (!createRes.ok) {\n      throw new Error(`Create milestone failed: ${createRes.status} ${createRes.statusText}`);\n    }\n    milestone = await createRes.json();\n  }\n\n  // Assign issue to milestone\n  if (milestone && milestone.number) {\n    const patchRes = await fetch(`https://api.github.com/repos/${repo}/issues/${issueNumber}`, {\n      method: 'PATCH',\n      headers,\n      body: JSON.stringify({ milestone: milestone.number })\n    });\n    if (!patchRes.ok) {\n      throw new Error(`Assign milestone failed: ${patchRes.status} ${patchRes.statusText}`);\n    }\n  }\n\n  return [{ json: { milestoneTitle, milestoneNumber: milestone?.number, issueNumber, assigned: true } }];\n} catch (error) {\n  console.error(`[Assign Milestone] Error: ${error.message}`);\n  return [{ json: { milestoneTitle, issueNumber, assigned: false, error: error.message } }];\n}"
            },
            "id": "assign-milestone",
            "name": "Assign Milestone",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1200,
                600
            ]
        },
