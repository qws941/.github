            "id": "is-opened-filter",
            "name": "Is Opened & Not Automated?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                720,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const title = ($json.issueTitle || '').toLowerCase();\nconst body = ($json.issueBody || '').toLowerCase();\nconst searchText = title + ' ' + body;\nconst existingLabels = $json.existingLabels || [];\n\nconst KEYWORD_MAP = {\n  'terraform': 'infra', 'infrastructure': 'infra',\n  'mcphub': 'svc:mcphub', 'opencode': 'svc:mcphub',\n  'grafana': 'svc:grafana', 'prometheus': 'svc:grafana', 'alerting': 'svc:grafana', 'dashboard': 'svc:grafana',\n  'elk': 'svc:elk', 'elasticsearch': 'svc:elk', 'logstash': 'svc:elk', 'kibana': 'svc:elk', 'filebeat': 'svc:elk',\n  'traefik': 'svc:traefik', 'reverse proxy': 'svc:traefik', 'routing': 'svc:traefik', 'certificate': 'svc:traefik',\n  'n8n': 'svc:n8n', 'workflow': 'svc:n8n', 'webhook': 'svc:n8n',\n  'blacklist': 'svc:blacklist',\n  'proxmox': 'svc:proxmox', 'ceph': 'svc:proxmox', 'lxc': 'svc:proxmox',\n  'security': 'P1-high', 'vulnerability': 'P1-high', 'cve': 'P1-high'\n};\n\nconst newLabels = new Set();\nfor (const [keyword, label] of Object.entries(KEYWORD_MAP)) {\n  if (searchText.includes(keyword) && !existingLabels.includes(label)) {\n    newLabels.add(label);\n  }\n}\n\nreturn [{\n  json: {\n    ...$json,\n    newLabels: [...newLabels],\n    hasNewLabels: newLabels.size > 0\n  }\n}];"
            },
