            "name": "Verify Slack",
            "parameters": {
                "jsCode": "const r = $input.first().json;\nif (r.ok !== true) {\n  throw new Error(`Slack API error: ${r.error || 'unknown'}`);\n}\nreturn [{ json: r }];"
