        {
            "typeVersion": 2,
            "id": "format-success",
            "name": "Format Success",
            "parameters": {
                "jsCode": "const r = $input.first().json;\nconst s = (r.data && r.data.summary) || {};\nconst processed = s.processed || 0;\nconst succeeded = s.succeeded || 0;\nconst courses = s.coursesDiscovered || 0;\n\nreturn [{\n  json: {\n    channel: 'C0A1RFH7VL4',\n    text: `\u2705 *HYCU \uc218\uac15 \ucd9c\uc11d \uc644\ub8cc*\\n\uacfc\ubaa9: ${courses}\uac1c | \ucc98\ub9ac: ${processed}\uac74 | \uc131\uacf5: ${succeeded}\uac74`\n  }\n}];"
            },
            "position": [
                910,
                150
            ],
            "type": "n8n-nodes-base.code"
        },
        {
            "id": "wait-retry",
            "name": "Wait 60s",
            "parameters": {
                "resume": "timeInterval",
                "unit": "seconds",
                "amount": 60
            },
            "position": [
                910,
                450
            ],
            "type": "n8n-nodes-base.wait",
            "typeVersion": 1.1
        },
        {
