                "specifyBody": "json",
                "url": "https://slack.com/api/chat.postMessage",
                "sendHeaders": false
            },
            "retryOnFail": true,
            "waitBetweenTries": 2000,
            "position": [
                1790,
                400
            ],
            "id": "slack-notify",
            "maxTries": 3
        },
        {
