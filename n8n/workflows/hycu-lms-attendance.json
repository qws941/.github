    {
      "typeVersion": 2,
      "id": "format-retry-ok",
      "name": "Format Retry OK",
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst s = (r.data && r.data.summary) || {};\nconst processed = s.processed || 0;\nconst succeeded = s.succeeded || 0;\nconst courses = s.coursesDiscovered || 0;\n\nreturn [{\n  json: {\n    channel: 'C0A1RFH7VL4',\n    text: `✅ *HYCU 수강 출석 완료 (재시도 성공)*\\n과목: ${courses}개 | 처리: ${processed}건 | 성공: ${succeeded}건`\n  }\n}];"
      },
      "position": [
        1570,
        350
      ],
      "type": "n8n-nodes-base.code"
    },
    {
      "position": [
        1570,
        550
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "id": "format-failure",
      "name": "Format Failure",
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst isN8nError = r.error === true;\nlet errorMsg;\n\nif (isN8nError) {\n  errorMsg = `HTTP_${r.httpCode || '???'}: ${r.message || 'Unknown'}`;\n} else if (r.error && typeof r.error === 'object') {\n  errorMsg = `${r.error.code || 'ERROR'}: ${r.error.message || 'Unknown'}`;\n} else {\n  errorMsg = r.message || r.error || 'Unknown error';\n}\n\nreturn [{\n  json: {\n    channel: 'C0A1RFH7VL4',\n    text: `❌ *HYCU 수강 출석 실패*\\n오류: ${errorMsg}\\n\\n초기 시도 및 재시도 모두 실패했습니다.`\n  }\n}];"
      }
    },
    {
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "name": "Slack Notify",
