      "typeVersion": 2,
      "id": "format-success",
      "name": "Format Success",
      "parameters": {
        "jsCode": "const r = $input.first().json;\nconst s = (r.data && r.data.summary) || {};\nconst processed = s.processed || 0;\nconst succeeded = s.succeeded || 0;\nconst courses = s.coursesDiscovered || 0;\n\nreturn [{\n  json: {\n    channel: 'C0A1RFH7VL4',\n    text: `✅ *HYCU 수강 출석 완료*\\n과목: ${courses}개 | 처리: ${processed}건 | 성공: ${succeeded}건`\n  }\n}];"
      },
      "position": [
        910,
        150
      ],
      "type": "n8n-nodes-base.code"
    },
