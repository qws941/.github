            ],
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "continueOnFail": true,
            "id": "retry-attendance",
            "name": "Retry Attendance",
            "parameters": {
                "method": "POST",
                "options": {
                    "timeout": 180000
                },
                "sendHeaders": true,
                "url": "={{ $env.HYCU_SERVICE_URL }}/api/attend",
                "authentication": "none",
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "x-api-key",
                            "value": "={{ $env.HYCU_SERVICE_API_KEY }}"
                        }
                    ]
                }
            }
        },
        {
            "position": [
                1350,
                450
            ],
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "id": "check-retry",
            "name": "Check Retry",
            "parameters": {
                "options": {},
                "conditions": {
                    "conditions": [
                        {
                            "id": "retry-check",
                            "leftValue": "={{ $json.success }}",
                            "operator": {
                                "operation": "true",
                                "type": "boolean"
                            },
                            "rightValue": ""
                        }
                    ],
                    "options": {
                        "typeValidation": "strict",
                        "caseSensitive": true,
                        "leftValue": ""
                    },
                    "combinator": "and"
                }
            }
        },
        {
            "typeVersion": 2,
            "id": "format-retry-ok",
            "name": "Format Retry OK",
            "parameters": {
                "jsCode": "const r = $input.first().json;\nconst s = (r.data && r.data.summary) || {};\nconst processed = s.processed || 0;\nconst succeeded = s.succeeded || 0;\nconst courses = s.coursesDiscovered || 0;\n\nreturn [{\n  json: {\n    channel: 'C0A1RFH7VL4',\n    text: `\u2705 *HYCU \uc218\uac15 \ucd9c\uc11d \uc644\ub8cc (\uc7ac\uc2dc\ub3c4 \uc131\uacf5)*\\n\uacfc\ubaa9: ${courses}\uac1c | \ucc98\ub9ac: ${processed}\uac74 | \uc131\uacf5: ${succeeded}\uac74`\n  }\n}];"
            },
            "position": [
                1570,
                350
            ],
            "type": "n8n-nodes-base.code"
        },
        {
            "position": [
                1570,
                550
            ],
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "id": "format-failure",
            "name": "Format Failure",
            "parameters": {
                "jsCode": "const r = $input.first().json;\nconst isN8nError = r.error === true;\nlet errorMsg;\n\nif (isN8nError) {\n  errorMsg = `HTTP_${r.httpCode || '???'}: ${r.message || 'Unknown'}`;\n} else if (r.error && typeof r.error === 'object') {\n  errorMsg = `${r.error.code || 'ERROR'}: ${r.error.message || 'Unknown'}`;\n} else {\n  errorMsg = r.message || r.error || 'Unknown error';\n}\n\nreturn [{\n  json: {\n    channel: 'C0A1RFH7VL4',\n    text: `\u274c *HYCU \uc218\uac15 \ucd9c\uc11d \uc2e4\ud328*\\n\uc624\ub958: ${errorMsg}\\n\\n\ucd08\uae30 \uc2dc\ub3c4 \ubc0f \uc7ac\uc2dc\ub3c4 \ubaa8\ub450 \uc2e4\ud328\ud588\uc2b5\ub2c8\ub2e4.`\n  }\n}];"
            }
        },
        {
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "name": "Slack Notify",
            "credentials": {
                "httpHeaderAuth": {
                    "id": "Oq6RplVhTJ3Rr96J",
                    "name": "Slack Bot Token"
                }
            },
            "parameters": {
                "method": "POST",
