        {
            "name": "Initialize Retry State",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                350,
                200
            ],
            "parameters": {
                "jsCode": "if (!$vars.RETRY_MAX_ATTEMPTS) throw new Error('n8n Variable RETRY_MAX_ATTEMPTS is not set.');\nif (!$vars.RETRY_BASE_DELAY_SECONDS) throw new Error('n8n Variable RETRY_BASE_DELAY_SECONDS is not set.');\nif (!$vars.RETRY_MAX_BACKOFF_SECONDS) throw new Error('n8n Variable RETRY_MAX_BACKOFF_SECONDS is not set.');\nconst input = $input.first().json;\nreturn {\n  ...input,\n  attempt: 1,\n  maxAttempts: Number($vars.RETRY_MAX_ATTEMPTS),\n  baseDelay: Number($vars.RETRY_BASE_DELAY_SECONDS),\n  maxBackoff: Number($vars.RETRY_MAX_BACKOFF_SECONDS),\n  rootTriggeredAt: input.triggeredAt || new Date().toISOString()\n};"
            },
            "id": "init-retry"
        },
        {
            "name": "Execute Queue Attempt",
            "type": "n8n-nodes-base.executeWorkflow",
            "typeVersion": 1,
            "position": [
                620,
                200
            ],
            "parameters": {
                "source": "database",
                "workflowId": "kRRZAx7krkcaCcpT"
            },
            "id": "execute-attempt"
        },
        {
            "typeVersion": 2,
            "position": [
                890,
                200
            ],
            "parameters": {
                "jsCode": "const attemptResult = $input.first().json;\nlet retryState;\ntry { retryState = $('Increment Attempt').first().json; }\ncatch (e) { retryState = $('Initialize Retry State').first().json; }\nreturn {\n  ...attemptResult,\n  params: retryState.params ?? attemptResult.params ?? {},\n  attempt: retryState.attempt,\n  maxAttempts: retryState.maxAttempts,\n  baseDelay: retryState.baseDelay,\n  maxBackoff: retryState.maxBackoff,\n  rootTriggeredAt: retryState.rootTriggeredAt\n};"
            },
            "id": "normalize-result",
            "name": "Normalize Attempt Result",
            "type": "n8n-nodes-base.code"
        },
        {
            "id": "if-success",
            "name": "Attempt Succeeded?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.1,
            "position": [
                1160,
                200
            ],
            "parameters": {
                "conditions": {
                    "conditions": [
                        {
                            "leftValue": "={{ $json.isSuccess }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "equals"
                            },
                            "id": "success-check"
                        }
                    ],
                    "combinator": "and",
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    }
                }
            }
        },
        {
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1700,
                80
            ],
            "parameters": {
                "jsCode": "const data = $input.first().json;\nreturn {\n  channel: data.channel,\n  status: data.status,\n  command: data.command,\n  duration: data.duration,\n  youtubeId: data.youtubeId,\n  outputUrl: data.outputPath,\n  errorMessage: data.errorMessage,\n  isSuccess: data.isSuccess,\n  timedOut: data.timedOut,\n  pollCount: data.pollCount,\n  source: 'pipeline',\n  notificationType: 'final',\n  attempt: data.attempt,\n  maxAttempts: data.maxAttempts,\n  reviewPassed: data.reviewPassed ?? false,\n  reviewNotes: data.reviewNotes ?? null,\n  loopCount: data.loopCount ?? 0\n};"
            },
            "id": "prepare-final-slack",
            "name": "Prepare Final Slack Input"
        },
        {
            "name": "Notify via Slack",
            "type": "n8n-nodes-base.executeWorkflow",
            "typeVersion": 1,
            "position": [
                1940,
                80
            ],
            "parameters": {
                "source": "database",
                "workflowId": "PV5yLgHNzNSlCmRT"
            },
            "id": "notify-slack"
        },
        {
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2180,
                80
            ],
            "parameters": {
                "jsCode": "const data = $('Normalize Attempt Result').first().json;\nreturn {\n  ...data,\n  attemptCount: data.attempt,\n  retriedFrom: data.rootTriggeredAt\n};"
            },
            "id": "return-result",
            "name": "Return Result"
        },
        {
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.1,
            "position": [
                1430,
                320
            ],
            "parameters": {
                "conditions": {
                    "combinator": "and",
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "retry-eligible",
                            "leftValue": "={{ ($json.attempt < $json.maxAttempts) && (($json.status === 'failed' || $json.timedOut) && !$json.youtubeId) }}",
                            "rightValue": true,
                            "operator": {
                                "operation": "equals",
                                "type": "boolean"
                            }
                        }
                    ]
                }
            },
            "id": "if-retry",
            "name": "Retry Eligible?"
        },
        {
            "position": [
                1700,
                320
            ],
            "parameters": {
                "jsCode": "const data = $input.first().json;\nconst delay = Math.min(data.baseDelay * Math.pow(2, data.attempt - 1), data.maxBackoff);\nreturn { ...data, backoffSeconds: delay };"
            },
            "id": "compute-backoff",
            "name": "Compute Backoff",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2
        },
        {
            "id": "retry-wait",
            "name": "Retry Wait",
            "type": "n8n-nodes-base.wait",
            "typeVersion": 1.1,
            "position": [
                1940,
                320
            ],
            "parameters": {
                "amount": "={{ $json.backoffSeconds }}",
                "unit": "seconds"
            }
        },
        {
            "name": "Increment Attempt",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2180,
                320
            ],
            "parameters": {
                "jsCode": "const data = $input.first().json;\nreturn { ...data, attempt: data.attempt + 1 };"
            },
            "id": "increment-attempt"
        },
        {
            "id": "review-output",
            "name": "Review Upload Output",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1440,
                80
            ],
            "parameters": {
                "mode": "runOnceForAllItems",
                "language": "javaScript",
                "jsCode": "const data = $('Normalize Attempt Result').first().json;\nconst notes = [];\nif (!data.youtubeId) notes.push('missing youtube id');\nif (!data.outputPath) notes.push('missing output path');\nif (data.errorMessage) notes.push(data.errorMessage);\nconst reviewPassed = notes.length === 0;\nreturn {\n  ...data,\n  reviewPassed,\n  reviewNotes: reviewPassed ? 'upload output looks complete' : notes.join('; ')\n};",
                "notice": ""
            }
        },
        {
            "id": "check-next-topic",
            "name": "Check Next Topic",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1712,
                -120
            ],
            "parameters": {
                "method": "GET",
                "url": "={{ $env.SUPABASE_URL }}/rest/v1/topics",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "={{ $env.SUPABASE_ANON_KEY }}"
                        },
                        {
                            "name": "Authorization",
                            "value": "=Bearer {{ $env.SUPABASE_ANON_KEY }}"
                        }
                    ]
                },
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "channel",
                            "value": "=eq.{{ $('Review Upload Output').first().json.channel }}"
                        },
                        {
                            "name": "is_used",
                            "value": "=eq.false"
                        },
                        {
                            "name": "select",
                            "value": "id"
                        },
                        {
                            "name": "order",
                            "value": "priority.desc,id.asc"
                        },
                        {
                            "name": "limit",
                            "value": "1"
                        }
                    ]
                }
            }
        },
        {
            "id": "prepare-next-upload",
            "name": "Prepare Next Upload",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1952,
                -120
            ],
            "parameters": {
                "mode": "runOnceForAllItems",
                "language": "javaScript",
                "jsCode": "const data = $('Review Upload Output').first().json;\nconst topics = Array.isArray($('Check Next Topic').first().json) ? $('Check Next Topic').first().json : [];\nconst active = Array.isArray($input.first().json) ? $input.first().json : [];\nconst loopCount = Number(data.loopCount || 0) + 1;\nconst hasNextTopic = topics.length > 0;\nconst hasActiveCommand = active.length > 0;\nreturn {\n  ...data,\n  loopCount,\n  hasNextTopic,\n  hasActiveCommand,\n  nextTopicId: hasNextTopic ? topics[0].id : null,\n  canContinue: data.reviewPassed && hasNextTopic && !hasActiveCommand\n};",
                "notice": ""
            }
        },
        {
            "id": "if-next-upload",
            "name": "Continue Upload Loop?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.1,
            "position": [
                2192,
